<svg width="16" height="16" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
  <!-- 方案1 Favicon 16x16 -->
  <defs>
    <linearGradient id="grad1" x1="0%" y1="100%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#3b82f6"/>
      <stop offset="100%" style="stop-color:#10b981"/>
    </linearGradient>
  </defs>
  <circle cx="8" cy="8" r="7" fill="white" stroke="url(#grad1)" stroke-width="1.5"/>
  <polyline points="3,8 5,6 7,7 11,4"
            fill="none"
            stroke="url(#grad1)"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"/>
  <circle cx="3" cy="8" r="1.5" fill="#3b82f6"/>
  <circle cx="5" cy="6" r="1.5" fill="#3b82f6"/>
  <circle cx="7" cy="7" r="1.5" fill="#f59e0b"/>
  <circle cx="11" cy="4" r="1.5" fill="#10b981"/>
