{
  "eslint.workingDirectories": [
    { "directory": "./", "changeProcessCWD": false },
    { "directory": "./quantmate-portal", "changeProcessCWD": true }
  ],
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.useWorkspaceDependencies": true,
  "eslint.run": "onType",
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 800,
  "eslint.alwaysShowStatus": true
}
